{
  "images": {
    "formats": ["image/avif", "image/webp"],
    "minimumCacheTTL": 2592000,
    "sizes": [640, 828, 1200, 1920]
  },
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ],
      "has": [
        {
          "type": "host",
          "value": "pattaya-love-beryl.vercel.app"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap-index.xml"
    }
  ],
  "redirects": [
    {
      "source": "/sitemap_index.xml",
      "destination": "/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/walking-street/iron-club/",
      "destination": "/nightlife/iron-club/",
      "permanent": true
    },
    {
      "source": "/walking-street/pin-up-a-go-go/",
      "destination": "/nightlife/pin-up-a-go-go/",
      "permanent": true
    },
    {
      "source": "/walking-street/xs-a-go-go/",
      "destination": "/nightlife/xs-a-go-go/",
      "permanent": true
    },
    {
      "source": "/soi-6/hotels-near-soi-6-pattaya-top-guest-friendly-budget-options-2025/",
      "destination": "/guides/hotels-near-soi-6/",
      "permanent": true
    },
    {
      "source": "/walking-street/",
      "destination": "/areas/walking-street/",
      "permanent": true
    },
    {
      "source": "/hotels/",
      "destination": "/stay/",
      "permanent": true
    },
    {
      "source": "/soi-6/",
      "destination": "/areas/soi-6/",
      "permanent": true
    },
    {
      "source": "/bangkok-to-pattaya/",
      "destination": "/guides/bangkok-to-pattaya/",
      "permanent": true
    },
    {
      "source": "/news/",
      "destination": "/guides/",
      "permanent": true
    },
    {
      "source": "/onlyfans/:path*",
      "destination": "/",
      "permanent": true
    }
  ]
}

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist. Let us help you find your way around Pattaya."
>
  <Navigation />

  <main class="min-h-[80vh] flex items-center justify-center bg-navy relative overflow-hidden grain">
    <!-- Decorative elements -->
    <div class="absolute top-20 left-10 text-[200px] md:text-[300px] font-extrabold font-headline text-white/[0.02] leading-none select-none pointer-events-none">
      404
    </div>
    <div class="absolute -bottom-20 -right-20 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute -top-20 -left-20 w-72 h-72 bg-coral/5 rounded-full blur-3xl"></div>

    <div class="relative z-10 text-center px-6 max-w-2xl mx-auto py-32">
      <!-- Fun emoji scene -->
      <div class="text-6xl md:text-8xl mb-6">
        <span class="inline-block animate-bounce" style="animation-delay: 0s;">🏖</span>
        <span class="inline-block animate-bounce" style="animation-delay: 0.1s;">🌴</span>
        <span class="inline-block animate-bounce" style="animation-delay: 0.2s;">🍹</span>
      </div>

      <h1 class="text-5xl md:text-7xl font-extrabold font-headline text-white tracking-tight mb-4">
        Lost in Pattaya?
      </h1>

      <p class="text-white/50 text-lg md:text-xl mb-4 max-w-lg mx-auto">
        This page doesn't exist — but don't worry, that's the beauty of getting lost here. Every wrong turn leads somewhere interesting.
      </p>

      <p class="text-white/30 text-sm mb-10">
        Error 404 — Page not found
      </p>

      <!-- Quick navigation -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
        <a href="/" class="cta-gradient text-white px-8 py-3.5 rounded-full text-sm font-bold uppercase tracking-widest hover:scale-105 active:scale-95 transition-transform shadow-lg shadow-primary/30 flex items-center gap-2">
          <Icon name="home" class="text-lg" />
          Back to Home
        </a>
        <a href="/guides/" class="bg-white/10 hover:bg-white/20 text-white px-8 py-3.5 rounded-full text-sm font-bold uppercase tracking-widest transition-all flex items-center gap-2">
          <Icon name="auto_stories" class="text-lg" />
          Browse Guides
        </a>
      </div>

      <!-- Popular destinations -->
      <div class="border-t border-white/10 pt-10">
        <p class="text-white/40 text-xs font-bold uppercase tracking-[0.2em] mb-6">Popular Destinations</p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href="/stay/" class="text-white/60 hover:text-white text-sm px-4 py-2 rounded-xl bg-white/5 hover:bg-white/10 transition-all flex items-center gap-1.5">
            <Icon name="hotel" class="text-sm" />
            Hotels
          </a>
          <a href="/nightlife/" class="text-white/60 hover:text-white text-sm px-4 py-2 rounded-xl bg-white/5 hover:bg-white/10 transition-all flex items-center gap-1.5">
            <Icon name="nightlife" class="text-sm" />
            Nightlife
          </a>
          <a href="/areas/walking-street/" class="text-white/60 hover:text-white text-sm px-4 py-2 rounded-xl bg-white/5 hover:bg-white/10 transition-all flex items-center gap-1.5">
            <Icon name="location_on" class="text-sm" />
            Walking Street
          </a>
          <a href="/guides/first-time-pattaya/" class="text-white/60 hover:text-white text-sm px-4 py-2 rounded-xl bg-white/5 hover:bg-white/10 transition-all flex items-center gap-1.5">
            <Icon name="flight_land" class="text-sm" />
            First Time?
          </a>
          <a href="/explore/" class="text-white/60 hover:text-white text-sm px-4 py-2 rounded-xl bg-white/5 hover:bg-white/10 transition-all flex items-center gap-1.5">
            <Icon name="explore" class="text-sm" />
            Explore
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

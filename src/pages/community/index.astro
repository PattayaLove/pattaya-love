---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import Icon from '../../components/Icon.astro';
---

<BaseLayout
  title="Pattaya.love Community — Connect with Fellow Travelers"
  description="Join the pattaya.love community. Get insider tips, connect with expats, and stay updated on events and deals in Pattaya."
>
  <Navigation transparent />

  <!-- Hero -->
  <header class="relative pt-32 pb-20 bg-navy grain">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
      <nav class="text-sm text-white/40 mb-8">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-white/70">Community</span>
      </nav>
      <h1 class="text-4xl md:text-6xl font-extrabold font-headline tracking-tight text-white mb-4">
        Community
      </h1>
      <p class="text-ink-faint text-lg max-w-2xl">
        Connect with fellow travelers, expats, and locals. Get insider tips you won't find in any guidebook.
      </p>
    </div>
  </header>

  <main class="max-w-5xl mx-auto px-6 lg:px-8 py-24">

    <!-- Facebook Community -->
    <section class="mb-20 reveal">
      <div class="bg-surface-card rounded-2xl p-10 md:p-14 shadow-lg border border-surface-high/30">
        <div class="flex items-start gap-4 mb-6">
          <div class="w-14 h-14 rounded-2xl bg-blue-500/10 flex items-center justify-center shrink-0">
            <Icon name="group" class="text-blue-600 text-2xl" />
          </div>
          <div>
            <h2 class="text-2xl font-extrabold font-headline text-ink mb-2">Join Our Facebook Community</h2>
            <p class="text-ink-muted">Connect with fellow travelers, share experiences, get real-time tips, and ask questions to people who actually live in Pattaya.</p>
          </div>
        </div>
        <a href="https://www.facebook.com/groups/pattaya.love" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-8 h-14 rounded-xl font-bold text-sm uppercase tracking-widest hover:scale-105 active:scale-95 transition-all shadow-md">
          <Icon name="group" class="text-lg" />
          Join on Facebook
        </a>
      </div>
    </section>

    <!-- Social Links -->
    <section class="mb-20 reveal">
      <h2 class="text-3xl font-extrabold font-headline tracking-tight text-ink mb-10">Follow Us</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="https://www.facebook.com/groups/pattaya.love" target="_blank" rel="noopener noreferrer" class="group bg-surface-card rounded-2xl p-8 border border-surface-high/30 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 text-center">
          <Icon name="group" class="text-4xl text-blue-600 mb-4 block" />
          <h3 class="font-headline font-bold text-lg text-ink mb-1">Facebook</h3>
          <p class="text-ink-muted text-sm">Join the community & get real-time tips</p>
        </a>
        <a href="https://www.instagram.com/pattaya.loves" target="_blank" rel="noopener noreferrer" class="group bg-surface-card rounded-2xl p-8 border border-surface-high/30 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 text-center">
          <Icon name="photo_camera" class="text-4xl text-pink-500 mb-4 block" />
          <h3 class="font-headline font-bold text-lg text-ink mb-1">Instagram</h3>
          <p class="text-ink-muted text-sm">Daily stories, reels & behind-the-scenes</p>
        </a>
        <a href="https://youtube.com/@pattaya_love" target="_blank" rel="noopener noreferrer" class="group bg-surface-card rounded-2xl p-8 border border-surface-high/30 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 text-center">
          <Icon name="smart_display" class="text-4xl text-red-500 mb-4 block" />
          <h3 class="font-headline font-bold text-lg text-ink mb-1">YouTube</h3>
          <p class="text-ink-muted text-sm">Hotel tours, venue walkthroughs & guides</p>
        </a>
        <a href="https://www.tiktok.com/@pattaya.love" target="_blank" rel="noopener noreferrer" class="group bg-surface-card rounded-2xl p-8 border border-surface-high/30 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 text-center">
          <Icon name="music_note" class="text-4xl text-ink mb-4 block" />
          <h3 class="font-headline font-bold text-lg text-ink mb-1">TikTok</h3>
          <p class="text-ink-muted text-sm">Quick tips & viral Pattaya moments</p>
        </a>
      </div>
    </section>

    <!-- Contribute -->
    <section class="reveal">
      <div class="bg-surface rounded-2xl p-10 md:p-14">
        <h2 class="text-2xl font-extrabold font-headline text-ink mb-4">Share Your Experience</h2>
        <p class="text-ink-muted text-lg mb-6 max-w-2xl">
          Have a tip, hotel review, or venue recommendation? We love hearing from travelers and locals. Reach out and your insights might be featured on the site.
        </p>
        <a href="mailto:info@pattaya.love" class="inline-flex items-center gap-2 cta-gradient text-white px-6 py-3 rounded-xl font-bold text-sm hover:scale-105 active:scale-95 transition-transform shadow-md shadow-primary/20">
          <Icon name="mail" class="text-lg" />
          Get in Touch
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

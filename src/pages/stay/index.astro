---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import OptImage from '../../components/OptImage.astro';

/* ─── Data ─── */
const allHotels = await getCollection('hotels', ({ data }) => !data.draft);
const hotels = allHotels.sort((a, b) => b.data.rating - a.data.rating);

/* ─── Unique areas for filter ─── */
const uniqueAreas = [...new Set(hotels.map(h => h.data.area))].sort();

/* ─── Normalize category to filter key ─── */
function normalizeCategory(cat: string): string {
  const c = cat.toLowerCase();
  if (c.includes('condo')) return 'condo';
  if (c.includes('villa')) return 'villa';
  if (c.includes('serviced') || c.includes('apartment')) return 'apartment';
  return 'hotel'; // Hotel, Resort, Inn, Guest house, Hostel, etc.
}

/* ─── Helpers ─── */
const priceLabels: Record<string, string> = {
  budget: 'Budget',
  'mid-range': 'Mid-Range',
  luxury: 'Luxury',
};

const priceColors: Record<string, { bg: string; text: string }> = {
  budget: { bg: 'bg-emerald-100', text: 'text-emerald-700' },
  'mid-range': { bg: 'bg-amber/15', text: 'text-amber' },
  luxury: { bg: 'bg-primary-light', text: 'text-primary' },
};

const amenityIcons: Record<string, string> = {
  Pool: 'pool',
  Spa: 'spa',
  Fitness: 'fitness_center',
  Restaurant: 'restaurant',
  Bar: 'local_bar',
  'Beach Access': 'beach_access',
  WiFi: 'wifi',
  Gym: 'fitness_center',
  Jacuzzi: 'hot_tub',
  AC: 'ac_unit',
  Parking: 'local_parking',
  'Room Service': 'room_service',
  Laundry: 'local_laundry_service',
  'Airport Shuttle': 'airport_shuttle',
  'Rooftop Bar': 'rooftop_deck',
  'Live Music': 'music_note',
  Kitchen: 'countertops',
  Security: 'shield',
  Staff: 'person',
};

const fallbackImage = 'https://lh3.googleusercontent.com/aida-public/AB6AXuCgSqW3kCmlM6PmuZYLGPW-S8fTTsXdj-I6SvEY81Pz4kw6bsL8gZtvAlzeQvMDEdmz0x2c6COj9OyVYbfYDxDdjBxdA21JKsyEgP5lpV1Yu_nj0iq5aIrgj1LXnkUiTZmeL_U9B7Qls6HiF0z83vvVp1gH81uBCEyWLMt9SCmWkSBzGCBbW29GmZcezpnYpVhePAkyjy6aK1PSGpocxwdhGVnxdygc-LPBleOgUSZJLtqUlA7q97vtyYZs_DBvxMfmo-1np0IkGzs';
---

<BaseLayout
  title="Best Places to Stay in Pattaya 2026 — Hotels, Condos, Villas & Apartments"
  description="Handpicked Pattaya hotels, condos, pool villas, and serviced apartments — from budget to luxury. Honest reviews, real photos, and best booking links for 2026."
>
  <Navigation transparent />

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 1. HERO HEADER                                  -->
  <!-- ═══════════════════════════════════════════════ -->
  <header class="relative w-full pt-32 pb-20 md:pt-40 md:pb-28 bg-navy overflow-hidden grain">
    <div class="absolute inset-0">
      <OptImage src="/images/areas/central-pattaya-aerial.jpg" alt="Aerial view of Central Pattaya hotels and skyline" width={1920} height={1080} class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-b from-navy/60 via-navy/70 to-navy/90"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-xs text-white/50 font-medium">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li><span class="material-symbols-outlined text-[10px]">chevron_right</span></li>
          <li class="text-white/80">Stay</li>
        </ol>
      </nav>

      <span class="font-headline text-[10px] md:text-xs font-bold uppercase tracking-[0.3em] text-primary-light mb-4 block">
        Handpicked by Experts
      </span>
      <h1 class="font-headline text-4xl sm:text-5xl md:text-6xl font-extrabold text-white tracking-tight leading-[1.05] mb-6 max-w-3xl">
        Best Places to Stay in Pattaya 2026
      </h1>
      <p class="text-white/65 text-lg md:text-xl max-w-2xl leading-relaxed">
        Handpicked hotels, condos, pool villas, and serviced apartments — from budget to luxury. Honest reviews, real photos, and the best booking links.
      </p>

      <!-- Stats -->
      <div class="mt-10 flex flex-wrap gap-8">
        <div class="flex items-center gap-3">
          <div class="w-11 h-11 rounded-xl bg-white/10 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary-light text-xl">hotel</span>
          </div>
          <div>
            <span class="text-white font-bold text-lg">{hotels.length}</span>
            <span class="text-white/50 text-sm block">Properties Reviewed</span>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-11 h-11 rounded-xl bg-white/10 flex items-center justify-center">
            <span class="material-symbols-outlined text-amber text-xl" style="font-variation-settings: 'FILL' 1;">star</span>
          </div>
          <div>
            <span class="text-white font-bold text-lg">4.0+</span>
            <span class="text-white/50 text-sm block">Average Rating</span>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-11 h-11 rounded-xl bg-white/10 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary-light text-xl">verified</span>
          </div>
          <div>
            <span class="text-white font-bold text-lg">100%</span>
            <span class="text-white/50 text-sm block">Guest-Friendly</span>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 2. FILTER BAR (sticky)                          -->
  <!-- ═══════════════════════════════════════════════ -->
  <div id="filter-bar" class="sticky top-0 z-40 bg-white shadow-[0_4px_20px_rgba(0,0,0,0.06)] border-b border-black/5">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-4">
      <!-- Mobile: Toggle button -->
      <div class="flex items-center justify-between md:hidden mb-0" id="filter-mobile-header">
        <span id="results-count-mobile" class="text-sm font-semibold text-ink">
          Showing {hotels.length} of {hotels.length} properties
        </span>
        <button
          id="filter-toggle"
          type="button"
          class="inline-flex items-center gap-1.5 bg-surface-low text-ink-muted px-4 py-2 rounded-full text-xs font-bold uppercase tracking-widest hover:bg-primary hover:text-white transition-colors"
        >
          <span class="material-symbols-outlined text-base">tune</span>
          Filters
        </button>
      </div>

      <!-- Filter controls (collapsible on mobile) -->
      <div id="filter-controls" class="hidden md:flex flex-col md:flex-row md:items-center gap-4 mt-4 md:mt-0">
        <!-- Search -->
        <div class="relative flex-shrink-0 w-full md:w-56">
          <span class="material-symbols-outlined text-ink-muted text-lg absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none">search</span>
          <input
            id="filter-search"
            type="text"
            placeholder="Search properties..."
            class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-black/10 bg-surface text-sm text-ink placeholder:text-ink-muted/60 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all"
          />
        </div>

        <!-- Area Select -->
        <div class="flex-shrink-0 w-full md:w-auto">
          <select
            id="filter-area"
            class="w-full md:w-auto appearance-none bg-surface-low text-ink text-sm font-medium px-4 py-2.5 pr-9 rounded-xl border border-black/10 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary cursor-pointer"
          >
            <option value="">All Areas</option>
            {uniqueAreas.map(area => (
              <option value={area}>{area}</option>
            ))}
          </select>
        </div>

        <!-- Category Pills -->
        <div class="flex items-center gap-2 flex-shrink-0 overflow-x-auto" id="filter-category-pills">
          <button type="button" data-category="" class="category-pill active text-[11px] font-bold px-4 py-2 rounded-full tracking-widest uppercase transition-all whitespace-nowrap bg-navy text-white">All</button>
          <button type="button" data-category="hotel" class="category-pill text-[11px] font-bold px-4 py-2 rounded-full tracking-widest uppercase transition-all whitespace-nowrap bg-surface-low text-ink-muted">Hotels</button>
          <button type="button" data-category="condo" class="category-pill text-[11px] font-bold px-4 py-2 rounded-full tracking-widest uppercase transition-all whitespace-nowrap bg-surface-low text-ink-muted">Condos</button>
          <button type="button" data-category="villa" class="category-pill text-[11px] font-bold px-4 py-2 rounded-full tracking-widest uppercase transition-all whitespace-nowrap bg-surface-low text-ink-muted">Pool Villas</button>
          <button type="button" data-category="apartment" class="category-pill text-[11px] font-bold px-4 py-2 rounded-full tracking-widest uppercase transition-all whitespace-nowrap bg-surface-low text-ink-muted">Apartments</button>
        </div>

        <!-- Price Pills -->
        <div class="flex items-center gap-2 flex-shrink-0 overflow-x-auto" id="filter-price-pills">
          <button type="button" data-price="" class="filter-pill active text-[11px] font-bold px-4 py-2 rounded-full tracking-widest uppercase transition-all whitespace-nowrap bg-primary text-white">All</button>
          <button type="button" data-price="budget" class="filter-pill text-[11px] font-bold px-4 py-2 rounded-full tracking-widest uppercase transition-all whitespace-nowrap bg-surface-low text-ink-muted">Budget</button>
          <button type="button" data-price="mid-range" class="filter-pill text-[11px] font-bold px-4 py-2 rounded-full tracking-widest uppercase transition-all whitespace-nowrap bg-surface-low text-ink-muted">Mid-Range</button>
          <button type="button" data-price="luxury" class="filter-pill text-[11px] font-bold px-4 py-2 rounded-full tracking-widest uppercase transition-all whitespace-nowrap bg-surface-low text-ink-muted">Luxury</button>
        </div>

        <!-- Rating Select -->
        <div class="flex-shrink-0 w-full md:w-auto">
          <select
            id="filter-rating"
            class="w-full md:w-auto appearance-none bg-surface-low text-ink text-sm font-medium px-4 py-2.5 pr-9 rounded-xl border border-black/10 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary cursor-pointer"
          >
            <option value="0">All Ratings</option>
            <option value="4.5">4.5+ Stars</option>
            <option value="4.0">4.0+ Stars</option>
            <option value="3.5">3.5+ Stars</option>
          </select>
        </div>

        <!-- Sort Select -->
        <div class="flex-shrink-0 w-full md:w-auto md:ml-auto">
          <select
            id="filter-sort"
            class="w-full md:w-auto appearance-none bg-surface-low text-ink text-sm font-medium px-4 py-2.5 pr-9 rounded-xl border border-black/10 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary cursor-pointer"
          >
            <option value="rating-desc">Rating (High to Low)</option>
            <option value="rating-asc">Rating (Low to High)</option>
            <option value="name-asc">Name (A-Z)</option>
          </select>
        </div>

        <!-- Results count (desktop) -->
        <div class="hidden md:block flex-shrink-0">
          <span id="results-count-desktop" class="text-sm font-semibold text-ink-muted whitespace-nowrap">
            Showing {hotels.length} of {hotels.length} properties
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 3. HOTEL GRID                                   -->
  <!-- ═══════════════════════════════════════════════ -->
  <section class="py-16 md:py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div id="hotel-grid" class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {hotels.map((hotel, i) => {
          const d = hotel.data;
          const heroImg = d.image || fallbackImage;
          const fullStars = Math.floor(d.rating);
          const hasHalf = d.rating % 1 >= 0.25 && d.rating % 1 < 0.75;
          const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);
          const colors = priceColors[d.priceRange] || priceColors['mid-range'];

          return (
            <article
              class:list={[
                'hotel-card reveal bg-surface-card rounded-2xl overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_20px_60px_rgb(0,0,0,0.08)] transition-all duration-500 group hover:-translate-y-1',
                `reveal-delay-${(i % 4) + 1}`,
              ]}
              data-area={d.area}
              data-price={d.priceRange}
              data-rating={d.rating.toString()}
              data-name={d.name.toLowerCase()}
              data-category={normalizeCategory(d.category)}
            >
              {/* Image */}
              <div class="relative h-56 md:h-64 overflow-hidden">
                <img
                  src={heroImg}
                  alt={`${d.name} — ${d.area}, Pattaya`}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>

                {/* Price Badge */}
                <div class="absolute top-4 left-4">
                  <span class:list={['text-[10px] font-bold px-3 py-1.5 rounded-full tracking-widest uppercase backdrop-blur-md', colors.bg, colors.text]}>
                    {priceLabels[d.priceRange]}
                  </span>
                </div>

                {/* Area Badge */}
                <div class="absolute top-4 right-4">
                  <span class="bg-white/90 backdrop-blur-md text-[10px] font-bold px-3 py-1.5 rounded-full text-ink tracking-wide flex items-center gap-1">
                    <span class="material-symbols-outlined text-xs">location_on</span>
                    {d.area}
                  </span>
                </div>
              </div>

              {/* Card Body */}
              <div class="p-6 md:p-7">
                {/* Name + Rating */}
                <div class="flex justify-between items-start mb-3">
                  <h2 class="font-headline font-bold text-xl text-ink group-hover:text-primary transition-colors leading-tight">
                    {d.name}
                  </h2>
                  <div class="flex items-center gap-1.5 shrink-0 ml-4">
                    <span class="material-symbols-outlined text-amber text-base" style="font-variation-settings: 'FILL' 1;">star</span>
                    <span class="text-base font-bold text-ink">{d.rating.toFixed(1)}</span>
                  </div>
                </div>

                {/* Star Rating Visual */}
                <div class="flex items-center gap-0.5 mb-4">
                  {Array.from({ length: fullStars }).map(() => (
                    <span class="material-symbols-outlined text-amber text-lg" style="font-variation-settings: 'FILL' 1;">star</span>
                  ))}
                  {hasHalf && (
                    <span class="material-symbols-outlined text-amber text-lg" style="font-variation-settings: 'FILL' 1;">star_half</span>
                  )}
                  {Array.from({ length: emptyStars }).map(() => (
                    <span class="material-symbols-outlined text-surface-high text-lg">star</span>
                  ))}
                </div>

                {/* Description */}
                <p class="text-ink-muted text-sm leading-relaxed mb-5 line-clamp-2">
                  {d.description}
                </p>

                {/* Amenity Icons */}
                {d.amenities.length > 0 && (
                  <div class="flex flex-wrap gap-2 mb-6 py-3 bg-surface-low rounded-xl px-3">
                    {d.amenities.slice(0, 5).map((amenity) => (
                      <span class="flex items-center gap-1 text-ink-muted text-xs" title={amenity}>
                        <span class="material-symbols-outlined text-base">{amenityIcons[amenity] || 'check_circle'}</span>
                        <span class="hidden sm:inline">{amenity}</span>
                      </span>
                    ))}
                    {d.amenities.length > 5 && (
                      <span class="text-ink-muted text-xs font-medium">+{d.amenities.length - 5} more</span>
                    )}
                  </div>
                )}

                {/* Buttons */}
                <div class="flex items-center gap-3">
                  <a
                    href={`/stay/${d.slug}/`}
                    class="flex-1 text-center border-2 border-primary text-primary px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-primary/5 transition-colors duration-200"
                  >
                    Read Review
                  </a>
                  {(d.bookingUrl || d.agodaUrl) ? (
                    <a
                      href={d.bookingUrl || d.agodaUrl}
                      target="_blank"
                      rel="noopener noreferrer nofollow"
                      class="flex-1 cta-gradient text-center text-white px-5 py-2.5 rounded-xl text-sm font-bold flex items-center justify-center gap-1.5 hover:scale-105 active:scale-95 transition-transform shadow-md shadow-primary/20"
                    >
                      Check Price
                      <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </a>
                  ) : (
                    <a
                      href={`/stay/${d.slug}/`}
                      class="flex-1 cta-gradient text-center text-white px-5 py-2.5 rounded-xl text-sm font-bold flex items-center justify-center gap-1.5 hover:scale-105 active:scale-95 transition-transform shadow-md shadow-primary/20"
                    >
                      Check Price
                      <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </a>
                  )}
                </div>
              </div>
            </article>
          );
        })}
      </div>

      <!-- Load More Button -->
      <div id="load-more-wrapper" class="mt-12 text-center">
        <button
          id="load-more-btn"
          type="button"
          class="inline-flex items-center gap-2 bg-primary text-white px-10 py-3.5 rounded-full text-sm font-bold uppercase tracking-widest hover:scale-105 active:scale-95 transition-transform shadow-md shadow-primary/20"
        >
          Load More
          <span class="material-symbols-outlined text-lg">expand_more</span>
        </button>
      </div>

      <!-- No Results Message -->
      <div id="no-results" class="hidden py-16 text-center">
        <span class="material-symbols-outlined text-5xl text-ink-muted/40 mb-4 block">search_off</span>
        <h3 class="font-headline font-bold text-xl text-ink mb-2">No properties found</h3>
        <p class="text-ink-muted text-sm">Try adjusting your filters or search term.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 3. TRUST / EEAT SECTION                         -->
  <!-- ═══════════════════════════════════════════════ -->
  <section class="py-20 md:py-24">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="font-headline text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3 block">Why Trust Our Reviews</span>
        <h2 class="text-3xl md:text-4xl font-extrabold font-headline tracking-tight text-ink">
          Every Hotel Personally Visited
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 reveal">
        <div class="text-center bg-surface rounded-2xl p-8">
          <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-primary/10 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary text-2xl">bed</span>
          </div>
          <h3 class="font-headline font-bold text-lg mb-2 text-ink">Real Stays</h3>
          <p class="text-ink-muted text-sm leading-relaxed">We book and stay at every hotel we review. No desk research or press releases.</p>
        </div>
        <div class="text-center bg-surface rounded-2xl p-8">
          <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-primary/10 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary text-2xl">groups</span>
          </div>
          <h3 class="font-headline font-bold text-lg mb-2 text-ink">Guest-Friendly Verified</h3>
          <p class="text-ink-muted text-sm leading-relaxed">Every listed hotel has been confirmed guest-friendly by our team. No surprises at check-in.</p>
        </div>
        <div class="text-center bg-surface rounded-2xl p-8">
          <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-primary/10 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary text-2xl">update</span>
          </div>
          <h3 class="font-headline font-bold text-lg mb-2 text-ink">Updated Regularly</h3>
          <p class="text-ink-muted text-sm leading-relaxed">Prices, policies, and conditions change. We revisit and refresh reviews every quarter.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 4. NEWSLETTER                                   -->
  <!-- ═══════════════════════════════════════════════ -->
  <section class="relative bg-coral py-24 overflow-hidden">
    <div class="absolute -top-20 -right-20 w-64 h-64 bg-white/5 rounded-full"></div>
    <div class="absolute -bottom-16 -left-16 w-48 h-48 bg-white/5 rounded-full"></div>
    <div class="max-w-2xl mx-auto px-6 text-center relative z-10">
      <h2 class="text-white text-3xl md:text-4xl font-extrabold font-headline tracking-tight mb-4">
        Join the Pattaya Community
      </h2>
      <p class="text-white/70 text-lg mb-10">
        Connect with travelers & expats, share experiences, and get real-time tips from people who live here.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://www.facebook.com/pattaya.xxx/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-white text-coral px-8 h-14 rounded-full font-bold text-sm uppercase tracking-widest hover:scale-105 active:scale-95 transition-transform shadow-lg whitespace-nowrap">
          <span class="material-symbols-outlined text-lg">group</span>
          Join on Facebook
        </a>
        <a href="https://www.instagram.com/pattaya.loves" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 border-2 border-white text-white px-8 h-14 rounded-full font-bold text-sm uppercase tracking-widest hover:bg-white hover:text-coral transition-all duration-300 whitespace-nowrap">
          <span class="material-symbols-outlined text-lg">photo_camera</span>
          Follow on Instagram
        </a>
      </div>
    </div>
  </section>

  <Footer />

  <!-- Mobile Bottom Nav -->
  <div class="md:hidden">
    <div class="fixed bottom-0 left-0 w-full flex justify-around items-center px-4 pb-[env(safe-area-inset-bottom,8px)] h-16 bg-white/95 backdrop-blur-xl z-50 shadow-[0_-8px_25px_rgba(0,0,0,0.05)]">
      <a href="/" class="flex flex-col items-center justify-center text-ink-muted">
        <span class="material-symbols-outlined">home</span>
        <span class="text-[8px] font-bold uppercase tracking-widest mt-0.5 font-headline">Home</span>
      </a>
      <a href="/stay/" class="flex flex-col items-center justify-center text-primary">
        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">bed</span>
        <span class="text-[8px] font-bold uppercase tracking-widest mt-0.5 font-headline">Stay</span>
      </a>
      <a href="/explore/" class="flex flex-col items-center justify-center text-ink-muted">
        <span class="material-symbols-outlined">explore</span>
        <span class="text-[8px] font-bold uppercase tracking-widest mt-0.5 font-headline">Explore</span>
      </a>
      <a href="/nightlife/" class="flex flex-col items-center justify-center text-ink-muted">
        <span class="material-symbols-outlined">nightlife</span>
        <span class="text-[8px] font-bold uppercase tracking-widest mt-0.5 font-headline">Night</span>
      </a>
      <a href="/guides/" class="flex flex-col items-center justify-center text-ink-muted">
        <span class="material-symbols-outlined">auto_stories</span>
        <span class="text-[8px] font-bold uppercase tracking-widest mt-0.5 font-headline">Journal</span>
      </a>
    </div>
  </div>
  <div class="h-16 md:hidden"></div>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- CLIENT-SIDE: Filtering, Sorting & Load More     -->
  <!-- ═══════════════════════════════════════════════ -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      /* ─── DOM refs ─── */
      const grid = document.getElementById('hotel-grid') as HTMLElement;
      const allCards = Array.from(grid.querySelectorAll('.hotel-card')) as HTMLElement[];
      const searchInput = document.getElementById('filter-search') as HTMLInputElement;
      const areaSelect = document.getElementById('filter-area') as HTMLSelectElement;
      const ratingSelect = document.getElementById('filter-rating') as HTMLSelectElement;
      const sortSelect = document.getElementById('filter-sort') as HTMLSelectElement;
      const pricePills = document.querySelectorAll('#filter-price-pills .filter-pill') as NodeListOf<HTMLButtonElement>;
      const categoryPills = document.querySelectorAll('#filter-category-pills .category-pill') as NodeListOf<HTMLButtonElement>;
      const loadMoreBtn = document.getElementById('load-more-btn') as HTMLButtonElement;
      const loadMoreWrapper = document.getElementById('load-more-wrapper') as HTMLElement;
      const noResults = document.getElementById('no-results') as HTMLElement;
      const countDesktop = document.getElementById('results-count-desktop') as HTMLElement;
      const countMobile = document.getElementById('results-count-mobile') as HTMLElement;
      const filterToggle = document.getElementById('filter-toggle') as HTMLButtonElement;
      const filterControls = document.getElementById('filter-controls') as HTMLElement;

      const PAGE_SIZE = 24;
      let visibleLimit = PAGE_SIZE;
      let activePrice = '';
      let activeCategory = '';

      /* ─── Mobile filter toggle ─── */
      filterToggle.addEventListener('click', () => {
        const isOpen = !filterControls.classList.contains('hidden');
        if (isOpen) {
          filterControls.classList.add('hidden');
          filterControls.classList.remove('flex');
        } else {
          filterControls.classList.remove('hidden');
          filterControls.classList.add('flex');
        }
      });

      /* ─── Price pill click ─── */
      pricePills.forEach(pill => {
        pill.addEventListener('click', () => {
          pricePills.forEach(p => {
            p.classList.remove('active', 'bg-primary', 'text-white');
            p.classList.add('bg-surface-low', 'text-ink-muted');
          });
          pill.classList.add('active', 'bg-primary', 'text-white');
          pill.classList.remove('bg-surface-low', 'text-ink-muted');
          activePrice = pill.dataset.price || '';
          visibleLimit = PAGE_SIZE;
          applyFilters();
        });
      });

      /* ─── Category pill click ─── */
      categoryPills.forEach(pill => {
        pill.addEventListener('click', () => {
          categoryPills.forEach(p => {
            p.classList.remove('active', 'bg-navy', 'text-white');
            p.classList.add('bg-surface-low', 'text-ink-muted');
          });
          pill.classList.add('active', 'bg-navy', 'text-white');
          pill.classList.remove('bg-surface-low', 'text-ink-muted');
          activeCategory = pill.dataset.category || '';
          visibleLimit = PAGE_SIZE;
          applyFilters();
        });
      });

      /* ─── Other filter listeners ─── */
      searchInput.addEventListener('input', () => { visibleLimit = PAGE_SIZE; applyFilters(); });
      areaSelect.addEventListener('change', () => { visibleLimit = PAGE_SIZE; applyFilters(); });
      ratingSelect.addEventListener('change', () => { visibleLimit = PAGE_SIZE; applyFilters(); });
      sortSelect.addEventListener('change', () => { applySorting(); applyFilters(); });

      /* ─── Load More ─── */
      loadMoreBtn.addEventListener('click', () => {
        visibleLimit += PAGE_SIZE;
        applyFilters();
      });

      /* ─── Sorting (rearranges DOM) ─── */
      function applySorting() {
        const val = sortSelect.value;
        const sorted = [...allCards].sort((a, b) => {
          if (val === 'rating-desc') {
            return parseFloat(b.dataset.rating || '0') - parseFloat(a.dataset.rating || '0');
          }
          if (val === 'rating-asc') {
            return parseFloat(a.dataset.rating || '0') - parseFloat(b.dataset.rating || '0');
          }
          // name-asc
          return (a.dataset.name || '').localeCompare(b.dataset.name || '');
        });
        sorted.forEach(card => grid.appendChild(card));
        // Update allCards order reference
        allCards.length = 0;
        allCards.push(...sorted);
      }

      /* ─── Core filter logic ─── */
      function applyFilters() {
        const searchTerm = searchInput.value.toLowerCase().trim();
        const areaVal = areaSelect.value;
        const ratingMin = parseFloat(ratingSelect.value) || 0;
        const priceVal = activePrice;
        const categoryVal = activeCategory;

        // Determine which cards match ALL filters
        const matched: HTMLElement[] = [];
        const notMatched: HTMLElement[] = [];

        allCards.forEach(card => {
          const cardArea = card.dataset.area || '';
          const cardPrice = card.dataset.price || '';
          const cardRating = parseFloat(card.dataset.rating || '0');
          const cardName = card.dataset.name || '';
          const cardCategory = card.dataset.category || '';

          const passArea = !areaVal || cardArea === areaVal;
          const passPrice = !priceVal || cardPrice === priceVal;
          const passRating = cardRating >= ratingMin;
          const passSearch = !searchTerm || cardName.includes(searchTerm);
          const passCategory = !categoryVal || cardCategory === categoryVal;

          if (passArea && passPrice && passRating && passSearch && passCategory) {
            matched.push(card);
          } else {
            notMatched.push(card);
          }
        });

        // Hide non-matching
        notMatched.forEach(card => {
          card.classList.add('hidden');
        });

        // Show matching up to visibleLimit, hide the rest
        const totalMatched = matched.length;
        matched.forEach((card, idx) => {
          if (idx < visibleLimit) {
            card.classList.remove('hidden');
          } else {
            card.classList.add('hidden');
          }
        });

        // Update count
        const showing = Math.min(visibleLimit, totalMatched);
        const countText = `Showing ${showing} of ${totalMatched} properties`;
        countDesktop.textContent = countText;
        countMobile.textContent = countText;

        // Load More visibility
        if (visibleLimit >= totalMatched) {
          loadMoreWrapper.classList.add('hidden');
        } else {
          loadMoreWrapper.classList.remove('hidden');
        }

        // No results
        if (totalMatched === 0) {
          noResults.classList.remove('hidden');
        } else {
          noResults.classList.add('hidden');
        }
      }

      /* ─── Initial run ─── */
      applyFilters();
    });
  </script>
</BaseLayout>

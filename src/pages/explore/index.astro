---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allAreas = await getCollection('areas', ({ data }) => !data.draft);
const allGuides = await getCollection('guides', ({ data }) => !data.draft);
const allHotels = await getCollection('hotels', ({ data }) => !data.draft);
const allVenues = await getCollection('venues', ({ data }) => !data.draft);

const exploreGuides = allGuides
  .filter((g) => ['general', 'transport', 'food', 'tips'].includes(g.data.category))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const areaImages: Record<string, string> = {
  'Walking Street': '/images/areas/walking-street.webp',
  'Soi 6': '/images/areas/soi-6.webp',
  'Jomtien Beach': '/images/areas/jomtien-beach-palms.webp',
  'Wongamat Beach': '/images/areas/wongamat-beach.webp',
  'Pratumnak Hill': '/images/areas/pratumnak-viewpoint.webp',
  'Naklua': '/images/areas/sanctuary-of-truth.webp',
  'East Pattaya (Dark Side)': '/images/areas/pattaya-city-sign.webp',
  'Soi Buakhao': '/images/areas/tree-town.webp',
};
const fallbackImage = '/images/areas/pattaya-beach-day.webp';

const categoryLabels: Record<string, string> = {
  general: 'General', transport: 'Transport', food: 'Food & Drink', tips: 'Tips',
};
import Icon from '../../components/Icon.astro';
---

<BaseLayout
  title="Explore Pattaya — Things to Do, Beaches & Hidden Gems"
  description="Discover the best things to do in Pattaya beyond the nightlife. Beaches, temples, island trips, food tours, and hidden gems curated by locals."
>
  <Navigation transparent />

  <!-- Hero -->
  <header class="relative h-[420px] lg:h-[500px] w-full flex items-end overflow-hidden">
    <img
      src={fallbackImage}
      alt="Explore Pattaya — beaches, temples and hidden gems"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-navy/80 via-navy/40 to-navy/20"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pb-12 w-full">
      <nav class="text-sm text-white/50 mb-4">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-white/80">Explore</span>
      </nav>
      <h1 class="text-4xl md:text-6xl font-extrabold font-headline text-white tracking-tight mb-3">
        Explore Pattaya
      </h1>
      <p class="text-white/60 text-lg max-w-xl">
        Beaches, temples, island trips & hidden gems — the side of Pattaya most tourists never see.
      </p>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Areas -->
    <section class="py-20">
      <div class="flex items-end justify-between mb-10 reveal">
        <div>
          <h2 class="text-3xl md:text-4xl font-extrabold font-headline tracking-tight text-ink">Explore by Area</h2>
          <div class="h-1 w-14 bg-primary mt-3 rounded-full"></div>
        </div>
        <a href="/areas/" class="text-primary font-bold text-sm uppercase tracking-widest flex items-center gap-1 hover:gap-2 transition-all">
          All Areas <Icon name="arrow_right_alt" class="text-lg" />
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {allAreas.map((area, i) => (
          <a href={`/areas/${area.data.slug}/`} class={`reveal reveal-delay-${i + 1} group relative rounded-2xl overflow-hidden aspect-[4/3]`}>
            <img
              src={area.data.image || areaImages[area.data.name] || fallbackImage}
              alt={area.data.name}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink/70 via-ink/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <h3 class="text-white font-headline text-2xl font-extrabold mb-1">{area.data.name}</h3>
              <p class="text-white/60 text-sm line-clamp-2">{area.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Attractions -->
    <section class="py-20 border-t border-surface-high/50">
      <div class="mb-10 reveal">
        <h2 class="text-3xl md:text-4xl font-extrabold font-headline tracking-tight text-ink">Top Attractions</h2>
        <div class="h-1 w-14 bg-primary mt-3 rounded-full"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { name: 'Sanctuary of Truth', area: 'Naklua', icon: 'temple_buddhist', desc: 'A 105-meter wooden temple covered in intricate carvings — Pattaya\'s most impressive architectural wonder. Under construction since 1981.', tag: 'Must See' },
          { name: 'Koh Larn (Coral Island)', area: 'Offshore', icon: 'sailing', desc: 'Crystal-clear water and white sand beaches just 45 minutes by ferry from Bali Hai Pier. The best day trip from Pattaya.', tag: 'Day Trip' },
          { name: 'Nong Nooch Tropical Garden', area: 'East Pattaya', icon: 'park', desc: 'Massive botanical garden with themed sections, Thai cultural shows, and elephant experiences. Allow half a day.', tag: 'Nature' },
          { name: 'Big Buddha (Wat Phra Yai)', area: 'Pratumnak Hill', icon: 'temple_buddhist', desc: '18-meter golden Buddha with panoramic views across Pattaya Bay. Free entry, modest dress required. Best at sunset.', tag: 'Culture' },
          { name: 'Pattaya Floating Market', area: 'East Pattaya', icon: 'store', desc: 'Four-region Thai food market on the water. Touristy but fun — great for photos and sampling dishes from across Thailand.', tag: 'Food' },
          { name: 'Ramayana Water Park', area: 'East Pattaya', icon: 'pool', desc: 'Thailand\'s largest water park with over 50 slides and attractions. Perfect for families and hot days.', tag: 'Family' },
          { name: 'Silverlake Vineyard', area: 'East Pattaya', icon: 'wine_bar', desc: 'Hilltop winery with panoramic views, a giant hillside Buddha, and surprisingly decent Thai wine.', tag: 'Views' },
          { name: 'Art in Paradise', area: 'Central Pattaya', icon: 'palette', desc: '3D art museum with interactive optical illusions. Great for Instagram photos and rainy day entertainment.', tag: 'Fun' },
          { name: 'Pattaya Viewpoint', area: 'Pratumnak Hill', icon: 'photo_camera', desc: 'The classic Pattaya panorama — curved bay, city skyline, and Koh Larn in the distance. Iconic photo spot.', tag: 'Views' },
        ].map((attraction, i) => (
          <div class={`reveal reveal-delay-${(i % 4) + 1} bg-surface-card rounded-2xl p-6 border border-surface-high/30 hover:shadow-lg transition-all duration-300`}>
            <div class="flex items-start justify-between mb-3">
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
                <Icon name={attraction.icon} class="text-primary text-2xl" />
              </div>
              <span class="text-[10px] font-bold uppercase tracking-widest text-ink-faint bg-surface-low px-3 py-1 rounded-full">{attraction.tag}</span>
            </div>
            <h3 class="font-headline font-bold text-lg text-ink mb-1">{attraction.name}</h3>
            <p class="text-ink-muted text-xs mb-3 flex items-center gap-1">
              <Icon name="location_on" class="text-xs" />
              {attraction.area}
            </p>
            <p class="text-ink-muted text-sm leading-relaxed">{attraction.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Guides -->
    <section class="py-20 border-t border-surface-high/50">
      <div class="flex items-end justify-between mb-10 reveal">
        <div>
          <h2 class="text-3xl md:text-4xl font-extrabold font-headline tracking-tight text-ink">Travel Guides</h2>
          <div class="h-1 w-14 bg-primary mt-3 rounded-full"></div>
        </div>
        <a href="/guides/" class="text-primary font-bold text-sm uppercase tracking-widest flex items-center gap-1 hover:gap-2 transition-all">
          All Guides <Icon name="arrow_right_alt" class="text-lg" />
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {exploreGuides.map((guide, i) => (
          <a href={`/guides/${guide.data.slug}/`} class={`reveal reveal-delay-${i + 1} group bg-surface-card rounded-2xl shadow-[0_4px_20px_-4px_rgba(0,0,0,0.06)] overflow-hidden hover:shadow-[0_20px_50px_-12px_rgba(185,5,56,0.1)] transition-all duration-500 hover:-translate-y-1`}>
            <div class="aspect-video bg-surface-low overflow-hidden">
              <img src={guide.data.image || '/images/areas/pattaya-drone-sunset.webp'} alt={guide.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
            </div>
            <div class="p-6">
              <span class="text-[10px] font-bold uppercase tracking-[0.15em] text-primary mb-2 block">
                {categoryLabels[guide.data.category] || guide.data.category}
              </span>
              <h3 class="text-lg font-bold font-headline text-ink mb-2 group-hover:text-primary transition-colors line-clamp-2">
                {guide.data.title}
              </h3>
              <p class="text-ink-muted text-sm line-clamp-2">{guide.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>

  <section class="relative bg-coral py-24 overflow-hidden">
    <div class="absolute -top-20 -right-20 w-64 h-64 bg-white/5 rounded-full"></div>
    <div class="absolute -bottom-16 -left-16 w-48 h-48 bg-white/5 rounded-full"></div>
    <div class="max-w-2xl mx-auto px-6 text-center relative z-10">
      <h2 class="text-white text-3xl md:text-4xl font-extrabold font-headline tracking-tight mb-4">
        Join the Pattaya Community
      </h2>
      <p class="text-white/70 text-lg mb-10">
        Connect with travelers & expats, share experiences, and get real-time tips from people who live here.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://www.facebook.com/groups/pattaya.love" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-white text-coral px-8 h-14 rounded-full font-bold text-sm uppercase tracking-widest hover:scale-105 active:scale-95 transition-transform shadow-lg whitespace-nowrap">
          <Icon name="group" class="text-lg" />
          Join on Facebook
        </a>
        <a href="https://www.instagram.com/pattaya.loves" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 border-2 border-white text-white px-8 h-14 rounded-full font-bold text-sm uppercase tracking-widest hover:bg-white hover:text-coral transition-all duration-300 whitespace-nowrap">
          <Icon name="photo_camera" class="text-lg" />
          Follow on Instagram
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

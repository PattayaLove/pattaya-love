---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Pattaya Travel & Nightlife Guide"
  description="Your ultimate guide to Pattaya - hotels, nightlife, restaurants, and insider tips for the best experience in Thailand's party capital."
>
  <main class="min-h-screen flex items-center justify-center bg-gray-950 text-white">
    <div class="text-center px-6">
      <h1 class="text-5xl md:text-7xl font-bold mb-4">
        pattaya<span class="text-pink-500">.love</span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-400 mb-8 max-w-2xl">
        Your ultimate guide to Pattaya's best hotels, nightlife, and hidden gems.
      </p>
      <p class="text-sm text-gray-600">Coming soon</p>
    </div>
  </main>
</BaseLayout>

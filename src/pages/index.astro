    image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuCzmjpIvbHvzazTBgQo9SzEpqF6ZfNhFbDcFsRMaf2AK4Cw0qZQ82oIxQFIhZvaARrGpzRj22Jy66UwYtlXHQctT6pBxmsOPtEgkhRGM_1znZEOySc72gr9um1vn4pJj-qpnebpDEfeUj_xL2e1IPVVH9j7TGQu4K8DwU60cnv_-C23zpLzLQ9E6YeR_x5yhBBp-gDKWVM_vDIHFEY1RFcLJL8gwzGJ0T775Cx-TtzU06a-DyWmDmwZui9ydQtTZInVTgjX0wYN6-ph',
    aspect: 'aspect-[4/5]',
  },
  {
    tag: 'Report',
    date: 'Dec 2025',
    title: 'Skyline Transformations: The High-Rise Evolution',
    description: '',
    href: '/guides/',
    image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuCWWCJBVza_vFSrdCCEPF5puHpjnoff7Yo_ugzNZVFPoHyB4B_6BbAIaRjxcw5a4zeXQN0j_ISxX_HESS-tQ3M-gurlXtkHZGRpW0WTcqdaEPZ2xJoUFU1MCxGuFQi2CeMuKPBQbVEiIfXqQRTdZool5AVZca8AiduzjaSIEW_kZBH4ihhoDZ7Zd3OZ_8Mg8bATHNMbJTEz3nCWkf5V3NtAROCgW-hAwQP-CHggspzOobmwwrBhvvK6EmRyuX2Rzd65Eyck1ZCMy1aM',
    aspect: 'aspect-[2/3]',
  },
];
---

<BaseLayout
  title="Pattaya Travel & Nightlife Guide 2026"
  description="Your complete Pattaya guide for 2026 — best hotels, nightlife, beaches, and expat tips. Handpicked recommendations from locals who live here."
>
  <Navigation transparent />

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 1. HERO — Editorial style                      -->
  <!-- ═══════════════════════════════════════════════ -->
  <header class="relative h-[700px] lg:h-[750px] w-full flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuCWWCJBVza_vFSrdCCEPF5puHpjnoff7Yo_ugzNZVFPoHyB4B_6BbAIaRjxcw5a4zeXQN0j_ISxX_HESS-tQ3M-gurlXtkHZGRpW0WTcqdaEPZ2xJoUFU1MCxGuFQi2CeMuKPBQbVEiIfXqQRTdZool5AVZca8AiduzjaSIEW_kZBH4ihhoDZ7Zd3OZ_8Mg8bATHNMbJTEz3nCWkf5V3NtAROCgW-hAwQP-CHggspzOobmwwrBhvvK6EmRyuX2Rzd65Eyck1ZCMy1aM"
        alt="Pattaya skyline at golden hour overlooking the Gulf of Thailand"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-navy/30 via-navy/40 to-navy/70"></div>
    </div>

    <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
      <span class="font-headline text-[11px] md:text-xs uppercase tracking-[0.4em] text-primary-light mb-6 block font-bold">
        The Tropical Concierge
      </span>
      <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold text-white mb-8 leading-[1.05] tracking-tight font-headline">
        Curating the Extraordinary<br class="hidden md:block" />
        in the Gulf of Thailand
      </h1>
      <p class="text-white/75 text-lg md:text-xl max-w-2xl mx-auto font-light leading-relaxed mb-12">
        An editorial guide for those who demand the finest stays, hidden gems, and vibrant nightlife — curated by locals who know every corner.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/guides/" class="glass text-white px-8 py-3.5 rounded-full font-headline text-sm font-bold flex items-center gap-2.5 hover:bg-white/15 transition-all duration-300">
          <span class="material-symbols-outlined text-lg">search</span>
          Explore Guides
        </a>
        <a href="/explore/" class="text-white font-headline text-sm font-bold border-b border-white/30 pb-1 hover:border-white transition-all duration-300">
          View Interactive Map
        </a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 text-white/30">
      <span class="text-[10px] uppercase tracking-[0.3em] font-medium">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-white/30 to-transparent animate-pulse"></div>
    </div>
  </header>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 2. TRENDING NOW — Floating card overlapping hero -->
  <!-- ═══════════════════════════════════════════════ -->
  <section class="max-w-7xl mx-auto px-6 lg:px-8 -mt-20 relative z-20 reveal">
    <div class="bg-surface-card rounded-3xl shadow-[0_25px_60px_-12px_rgba(0,0,0,0.15)] p-8 md:p-12">
      <div class="flex items-center justify-between mb-10">
        <h2 class="font-headline text-2xl font-bold tracking-tight text-ink">Trending Now</h2>
        <a href="/guides/" class="group flex items-center gap-2 text-primary font-bold text-sm uppercase tracking-widest hover:gap-3 transition-all duration-300">
          View All
          <span class="material-symbols-outlined text-lg">arrow_right_alt</span>
        </a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-5 md:gap-6">
        {trendingItems.map((item, i) => (
          <a
            href={item.href}
            class:list={['group', i > 3 ? 'hidden sm:block' : '']}
          >
            <div class="aspect-square rounded-2xl overflow-hidden mb-3 shadow-[0_4px_15px_-3px_rgba(0,0,0,0.08)]">
              <img
                src={item.image}
                alt={item.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <span class="text-[10px] uppercase font-bold text-primary tracking-widest">{item.label}</span>
            <p class="text-xs font-bold text-ink mt-1 line-clamp-1">{item.title}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 3–6. SILO SECTIONS — Alternating asymmetric     -->
  <!-- ═══════════════════════════════════════════════ -->
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-24 md:py-32">
    <div class="space-y-28 md:space-y-32">
      {siloSections.map((silo) => (
        <section id={silo.id} class="reveal grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          {/* Text column */}
          <div class:list={[
            silo.imageRight ? 'order-2 lg:order-1' : 'order-2 lg:order-2',
          ]}>
            <span class="font-headline text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] text-primary mb-4 block">
              {silo.sectionLabel}
            </span>
            <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tight text-ink mb-6">
              {silo.title}
            </h2>
            <p class="text-ink-secondary text-lg leading-relaxed mb-8">
              {silo.description}
            </p>

            {/* Featured article card */}
            <div class="bg-surface-low p-7 md:p-8 rounded-2xl">
              <span class="text-[10px] font-bold uppercase tracking-widest text-primary mb-2 block">
                {silo.featureLabel}
              </span>
              <h4 class="font-headline text-xl font-bold text-ink mb-3 leading-snug">
                {silo.featureTitle}
              </h4>
              <p class="text-sm text-ink-muted mb-6 leading-relaxed">
                {silo.featureDesc}
              </p>
              <a href={silo.featureHref} class="inline-flex items-center text-primary font-bold text-sm uppercase tracking-widest group">
                {silo.featureCta}
                <span class="material-symbols-outlined ml-2 transition-transform duration-300 group-hover:translate-x-1">arrow_right_alt</span>
              </a>
            </div>
          </div>

          {/* Image column */}
          <div class:list={[
            'rounded-3xl overflow-hidden aspect-square lg:aspect-[4/3] shadow-[0_25px_50px_-12px_rgba(0,0,0,0.12)] relative group',
            silo.imageRight ? 'order-1 lg:order-2' : 'order-1 lg:order-1',
          ]}>
            <img
              src={silo.image}
              alt={silo.imageAlt}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          </div>
        </section>
      ))}
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 7. HOTEL SPOTLIGHT — Affiliate CTAs              -->
  <!-- ═══════════════════════════════════════════════ -->
  <section class="py-24 md:py-32 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-14 gap-4 reveal">
        <div>
          <span class="font-headline text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3 block">Handpicked by Experts</span>
          <h2 class="text-4xl md:text-5xl font-extrabold font-headline tracking-tight text-ink">
            Top-Rated Hotels
          </h2>
        </div>
        <a href="/stay/" class="group flex items-center gap-2 text-primary font-bold text-sm uppercase tracking-widest hover:gap-3 transition-all duration-300">
          View All Hotels
          <span class="material-symbols-outlined text-lg">east</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {hotels.map((hotel, i) => (
          <div class:list={[
            'reveal bg-surface-card rounded-2xl overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_20px_60px_rgb(0,0,0,0.08)] transition-all duration-500 group hover:-translate-y-1',
            `reveal-delay-${i + 1}`,
          ]}>
            <div class="relative h-56 overflow-hidden">
              <img
                src={hotel.image}
                alt={hotel.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
              <div class="absolute top-4 left-4">
                <span class="bg-white/90 backdrop-blur-md text-[10px] font-bold px-3 py-1.5 rounded-full text-primary tracking-widest uppercase">
                  {hotel.badge}
                </span>
              </div>
              <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-md px-3 py-1.5 rounded-full text-xs font-semibold text-ink">
                {hotel.area}
              </div>
            </div>
            <div class="p-6">
              <div class="flex justify-between items-start mb-3">
                <h3 class="font-headline font-bold text-lg text-ink">{hotel.name}</h3>
                <div class="flex items-center gap-1">
                  <span class="material-symbols-outlined text-amber text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
                  <span class="text-sm font-bold text-ink">{hotel.rating}</span>
                </div>
              </div>
              <div class="flex gap-3 mb-5 py-3 bg-surface-low rounded-xl px-3">
                {hotel.amenities.map((amenity) => (
                  <span class="flex items-center gap-1 text-ink-muted text-sm" title={amenityLabels[amenity]}>
                    <span class="material-symbols-outlined text-lg">{amenity}</span>
                  </span>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <div>
                  <span class="text-2xl font-extrabold text-primary">{hotel.price}</span>
                  <span class="text-ink-muted text-sm">/night</span>
                </div>
                <button class="cta-gradient px-5 py-2.5 rounded-xl text-white text-sm font-bold flex items-center gap-1.5 hover:scale-105 active:scale-95 transition-transform shadow-md shadow-primary/20">
                  Check Price
                  <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 8. THE PATTAYA JOURNAL — Masonry grid            -->
  <!-- ═══════════════════════════════════════════════ -->
  <section class="py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-6 reveal">
        <div class="max-w-2xl">
          <span class="font-headline text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] text-primary mb-4 block">
            The Heart of pattaya.love
          </span>
          <h2 class="font-headline text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-ink">
            The Pattaya Journal
          </h2>
          <p class="mt-4 text-ink-secondary text-lg md:text-xl leading-relaxed">
            Immersive long-reads and daily insights for the global resident.
          </p>
        </div>
        <a href="/guides/" class="group flex items-center gap-2 text-primary font-bold text-sm uppercase tracking-widest hover:gap-3 transition-all duration-300 shrink-0">
          View All Stories
          <span class="material-symbols-outlined text-lg">arrow_right_alt</span>
        </a>
      </div>

      <div class="journal-masonry">
        {journalArticles.map((article) => (
          <a href={article.href} class="journal-masonry-item group cursor-pointer block">
            <div class="overflow-hidden rounded-2xl md:rounded-3xl mb-5">
              <img
                src={article.image}
                alt={article.title}
                class:list={['w-full object-cover group-hover:scale-105 transition-transform duration-700', article.aspect]}
                loading="lazy"
              />
            </div>
            <div class="flex items-center gap-3 mb-3">
              <span class="text-[10px] font-bold uppercase tracking-widest text-primary bg-primary-light px-3 py-1.5 rounded-full">
                {article.tag}
              </span>
              <span class="text-xs text-ink-muted">{article.date}</span>
            </div>
            <h4 class="font-headline text-lg md:text-xl font-bold text-ink mb-2 leading-tight group-hover:text-primary transition-colors duration-300">
              {article.title}
            </h4>
            {article.description && (
              <p class="text-ink-muted text-sm leading-relaxed line-clamp-3">{article.description}</p>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 9. TRUST / EEAT SIGNALS                         -->
  <!-- ═══════════════════════════════════════════════ -->
  <section class="py-24 bg-surface">
    <div class="max-w-5xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-14 reveal">
        <span class="font-headline text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] text-primary mb-3 block">Why Trust Us</span>
        <h2 class="text-3xl md:text-4xl font-extrabold font-headline tracking-tight text-ink">
          Built on Real Experience
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 reveal">
        <div class="text-center bg-surface-card rounded-2xl p-8 shadow-[0_4px_20px_-4px_rgba(0,0,0,0.04)] hover:shadow-[0_12px_40px_-8px_rgba(0,0,0,0.06)] transition-all duration-500">
          <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-primary/10 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary text-2xl">verified</span>
          </div>
          <h3 class="font-headline font-bold text-lg mb-2 text-ink">Local Expertise</h3>
          <p class="text-ink-muted text-sm leading-relaxed">Written by expats who live and breathe Pattaya. Real insights, not tourist cliches.</p>
        </div>
        <div class="text-center bg-surface-card rounded-2xl p-8 shadow-[0_4px_20px_-4px_rgba(0,0,0,0.04)] hover:shadow-[0_12px_40px_-8px_rgba(0,0,0,0.06)] transition-all duration-500">
          <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-primary/10 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary text-2xl">update</span>
          </div>
          <h3 class="font-headline font-bold text-lg mb-2 text-ink">Always Up-to-Date</h3>
          <p class="text-ink-muted text-sm leading-relaxed">We revisit and update every guide regularly. No stale info from 3 years ago.</p>
        </div>
        <div class="text-center bg-surface-card rounded-2xl p-8 shadow-[0_4px_20px_-4px_rgba(0,0,0,0.04)] hover:shadow-[0_12px_40px_-8px_rgba(0,0,0,0.06)] transition-all duration-500">
          <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-primary/10 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary text-2xl">handshake</span>
          </div>
          <h3 class="font-headline font-bold text-lg mb-2 text-ink">Honest Reviews</h3>
          <p class="text-ink-muted text-sm leading-relaxed">No paid placements. Our affiliate partnerships never influence our ratings.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 10. NEWSLETTER                                  -->
  <!-- ═══════════════════════════════════════════════ -->
  <section class="relative bg-coral py-24 overflow-hidden">
    <div class="absolute -top-20 -right-20 w-64 h-64 bg-white/5 rounded-full"></div>
    <div class="absolute -bottom-16 -left-16 w-48 h-48 bg-white/5 rounded-full"></div>
    <div class="max-w-2xl mx-auto px-6 text-center relative z-10">
      <h2 class="text-white text-3xl md:text-4xl font-extrabold font-headline tracking-tight mb-4">
        Join the Pattaya Community
      </h2>
      <p class="text-white/70 text-lg mb-10">
        Connect with travelers & expats, share experiences, and get real-time tips from people who live here.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://www.facebook.com/pattaya.xxx/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-white text-coral px-8 h-14 rounded-full font-bold text-sm uppercase tracking-widest hover:scale-105 active:scale-95 transition-transform shadow-lg whitespace-nowrap">
          <span class="material-symbols-outlined text-lg">group</span>
          Join on Facebook
        </a>
        <a href="https://www.instagram.com/pattaya.loves" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 border-2 border-white text-white px-8 h-14 rounded-full font-bold text-sm uppercase tracking-widest hover:bg-white hover:text-coral transition-all duration-300 whitespace-nowrap">
          <span class="material-symbols-outlined text-lg">photo_camera</span>
          Follow on Instagram
        </a>
      </div>
    </div>
  </section>

  <!-- 11. Footer -->
  <Footer />

  <!-- ═══════════════════════════════════════════════ -->
  <!-- 12. MOBILE BOTTOM NAV — Fixed glassmorphic       -->
  <!-- ═══════════════════════════════════════════════ -->
  <div class="md:hidden">
    <div class="fixed bottom-0 left-0 w-full flex justify-around items-center px-4 pb-[env(safe-area-inset-bottom,8px)] h-16 bg-white/95 backdrop-blur-xl z-50 shadow-[0_-8px_25px_rgba(0,0,0,0.05)]">
      <a href="/" class="flex flex-col items-center justify-center text-primary">
        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">home</span>
        <span class="text-[8px] font-bold uppercase tracking-widest mt-0.5 font-headline">Home</span>
      </a>
      <a href="/stay/" class="flex flex-col items-center justify-center text-ink-muted">
        <span class="material-symbols-outlined">bed</span>
        <span class="text-[8px] font-bold uppercase tracking-widest mt-0.5 font-headline">Stay</span>
      </a>
      <a href="/explore/" class="flex flex-col items-center justify-center text-ink-muted">
        <span class="material-symbols-outlined">explore</span>
        <span class="text-[8px] font-bold uppercase tracking-widest mt-0.5 font-headline">Explore</span>
      </a>
      <a href="/nightlife/" class="flex flex-col items-center justify-center text-ink-muted">
        <span class="material-symbols-outlined">nightlife</span>
        <span class="text-[8px] font-bold uppercase tracking-widest mt-0.5 font-headline">Night</span>
      </a>
      <a href="/guides/" class="flex flex-col items-center justify-center text-ink-muted">
        <span class="material-symbols-outlined">auto_stories</span>
        <span class="text-[8px] font-bold uppercase tracking-widest mt-0.5 font-headline">Journal</span>
      </a>
    </div>
  </div>

  <!-- Bottom spacer for mobile nav -->
  <div class="h-16 md:hidden"></div>
</BaseLayout>

<style>
  /* Masonry grid using CSS columns */
  .journal-masonry {
    column-count: 1;
    column-gap: 2rem;
  }
  @media (min-width: 768px) {
    .journal-masonry {
      column-count: 2;
    }
  }
  @media (min-width: 1024px) {
    .journal-masonry {
      column-count: 3;
    }
  }
  .journal-masonry-item {
    break-inside: avoid;
    margin-bottom: 2rem;
  }
</style>

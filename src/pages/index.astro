---

<BaseLayout
  title="Pattaya Travel & Nightlife Guide"
  description="Your ultimate guide to Pattaya — hotels, nightlife, hidden gems, and expat life. Handpicked recommendations from local experts."
>
  <Navigation />

  <!-- ═══════════════════════════════════════════ -->
  <!-- HERO                                        -->
  <!-- ═══════════════════════════════════════════ -->
  <header class="relative h-screen w-full flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuBYD2OGzWrVyQGX1GEIp15SsIRTKl-ofV890IMqngrO_zV_iyXxqaINdM-b9sCkygPfdceyixhIsnz1Q7ueR_QNI-15AwvwbOS_bVL6MvYNqmE_hgCj3R9SP5T7JibkhKP4RjdX2HRQWFxL0IVkNdT9495xZOLhg57LEnqcesdEoW_gxKO465NNCrVmf3h4FtFZ8eMAvqpAzcqWw1SltndAShcbcIEMuFmd17kpBKc9OIXUziVbnSna9-6LjP1dJOBTLTw6srJAlL4"
        alt="Aerial view of Pattaya Bay at golden hour"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-navy/40 via-navy/30 to-navy/80"></div>
    </div>

    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
      <h1 class="text-5xl sm:text-6xl md:text-8xl font-extrabold text-white mb-6 leading-[0.95] tracking-tight font-headline">
        Discover Pattaya<br />
        <span class="text-primary-light">Like Never Before</span>
      </h1>
      <p class="text-lg md:text-xl text-white/60 mb-12 font-light max-w-xl mx-auto">
        Hotels, Nightlife, Hidden Gems & Expat Life — curated by locals who know every corner.
      </p>

      <div class="glass p-3 md:p-5 rounded-3xl max-w-2xl mx-auto shadow-2xl">
        <div class="flex flex-wrap gap-2 mb-4 px-1">
          <button class="px-5 py-2 rounded-full bg-white text-ink text-sm font-semibold transition-all shadow-sm">Hotels</button>
          <button class="px-5 py-2 rounded-full bg-white/10 text-white hover:bg-white/20 text-sm font-medium transition-all">Nightlife</button>
          <button class="px-5 py-2 rounded-full bg-white/10 text-white hover:bg-white/20 text-sm font-medium transition-all">Things to Do</button>
          <button class="px-5 py-2 rounded-full bg-white/10 text-white hover:bg-white/20 text-sm font-medium transition-all">Guides</button>
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
          <div class="relative flex-grow">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-white/40 text-xl">search</span>
            <input
              type="text"
              placeholder="Search hotels, venues, guides..."
              class="w-full bg-white/10 border-0 text-white placeholder-white/40 pl-12 pr-4 py-4 rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary/60 text-sm"
            />
          </div>
          <button class="cta-gradient text-white px-8 py-4 rounded-2xl font-bold text-sm hover:scale-[1.03] active:scale-95 transition-transform duration-200 shadow-lg shadow-primary/30 flex items-center justify-center gap-2">
            Search
            <span class="material-symbols-outlined text-lg">arrow_forward</span>
          </button>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 text-white/30">
      <span class="text-[10px] uppercase tracking-[0.3em] font-medium">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-white/30 to-transparent animate-pulse"></div>
    </div>
  </header>

  <!-- ═══════════════════════════════════════════ -->
  <!-- CATEGORY CARDS                              -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-24 px-6 lg:px-8 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {categories.map((cat, i) => (
        <a href={cat.href} class={`reveal reveal-delay-${i + 1} group relative aspect-[4/3] rounded-2xl overflow-hidden cursor-pointer`}>
          <img
            src={cat.image}
            alt={cat.title}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-ink/70 via-ink/10 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <div class="flex items-center justify-between">
              <div>
                <h3 class="text-white font-headline text-xl font-bold mb-1">{cat.title}</h3>
                <p class="text-white/60 text-sm">{cat.description}</p>
              </div>
              <span class="material-symbols-outlined text-white/60 group-hover:text-white group-hover:translate-x-1 transition-all duration-300">arrow_forward</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- TRENDING GUIDES                             -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-14 gap-4 reveal">
        <div>
          <h2 class="text-4xl md:text-5xl font-extrabold font-headline tracking-tight text-ink">
            Trending Guides
          </h2>
          <div class="h-1 w-16 bg-primary mt-4 rounded-full"></div>
        </div>
        <a href="/guides/" class="group flex items-center gap-2 text-primary font-bold text-sm uppercase tracking-widest hover:gap-3 transition-all duration-300">
          View All
          <span class="material-symbols-outlined text-lg">arrow_right_alt</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {guides.map((guide, i) => (
          <a href={guide.href} class={`reveal reveal-delay-${i + 1} group bg-surface-card rounded-2xl shadow-[0_4px_20px_-4px_rgba(0,0,0,0.06)] overflow-hidden hover:shadow-[0_20px_50px_-12px_rgba(185,5,56,0.1)] transition-all duration-500 hover:-translate-y-1`}>
            <div class="aspect-video w-full overflow-hidden relative">
              <img
                src={guide.image}
                alt={guide.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute top-4 left-4">
                <span class="inline-flex items-center px-3.5 py-1.5 bg-primary text-white text-[10px] font-bold uppercase tracking-[0.15em] rounded-full shadow-md">
                  {guide.category}
                </span>
              </div>
            </div>
            <div class="p-7">
              <h3 class="text-lg font-bold font-headline text-ink mb-3 group-hover:text-primary transition-colors duration-300 line-clamp-2">
                {guide.title}
              </h3>
              <div class="flex items-center gap-3 text-ink-muted text-sm">
                <span class="flex items-center gap-1">
                  <span class="material-symbols-outlined text-base" style="font-variation-settings: 'opsz' 20;">calendar_today</span>
                  {guide.date}
                </span>
                <span class="opacity-30">&middot;</span>
                <span class="flex items-center gap-1">
                  <span class="material-symbols-outlined text-base" style="font-variation-settings: 'opsz' 20;">schedule</span>
                  {guide.readTime}
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- HOTEL SPOTLIGHT                             -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-24 bg-surface-card">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-14 gap-4 reveal">
        <div>
          <h2 class="text-4xl md:text-5xl font-extrabold font-headline tracking-tight text-ink">
            Top-Rated Hotels
          </h2>
          <p class="text-ink-muted mt-2 text-lg">Handpicked by local experts</p>
        </div>
        <a href="/stay/" class="group flex items-center gap-2 text-primary font-bold text-sm uppercase tracking-widest hover:gap-3 transition-all duration-300">
          View All Hotels
          <span class="material-symbols-outlined text-lg">east</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {hotels.map((hotel, i) => (
          <div class={`reveal reveal-delay-${i + 1} bg-surface-card rounded-2xl overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_20px_60px_rgb(0,0,0,0.08)] transition-all duration-500 group border border-surface-high/50`}>
            <div class="relative h-56 overflow-hidden">
              <img
                src={hotel.image}
                alt={hotel.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
              <div class="absolute top-4 left-4">
                <span class="bg-white/90 backdrop-blur-md text-[10px] font-bold px-3 py-1.5 rounded-full text-primary tracking-widest uppercase">
                  {hotel.badge}
                </span>
              </div>
              <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-md px-3 py-1.5 rounded-full text-xs font-semibold text-ink">
                {hotel.area}
              </div>
            </div>
            <div class="p-6">
              <div class="flex justify-between items-start mb-3">
                <h3 class="font-headline font-bold text-lg text-ink">{hotel.name}</h3>
                <div class="flex items-center gap-1">
                  <span class="material-symbols-outlined text-amber text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
                  <span class="text-sm font-bold text-ink">{hotel.rating}</span>
                </div>
              </div>
              <div class="flex gap-3 mb-5 py-3 border-y border-surface-high/50">
                {hotel.amenities.map((amenity) => (
                  <span class="flex items-center gap-1 text-ink-muted text-sm" title={amenityLabels[amenity]}>
                    <span class="material-symbols-outlined text-lg">{amenity}</span>
                  </span>
                ))}
              </div>
              <div class="flex items-center justify-between">
                <div>
                  <span class="text-2xl font-extrabold text-primary">{hotel.price}</span>
                  <span class="text-ink-muted text-sm">/night</span>
                </div>
                <button class="cta-gradient px-5 py-2.5 rounded-xl text-white text-sm font-bold flex items-center gap-1.5 hover:scale-105 active:scale-95 transition-transform shadow-md shadow-primary/20">
                  Check Price
                  <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- AREA SPOTLIGHT                              -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="py-24 bg-navy relative grain overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
      <div class="text-center mb-16 reveal">
        <h2 class="text-4xl md:text-5xl font-extrabold font-headline tracking-tight text-white">
          Explore by Area
        </h2>
        <p class="text-ink-faint mt-3 text-lg max-w-xl mx-auto">
          Each neighborhood has its own character. Find yours.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[250px]">
        {areas.map((area, i) => (
          <a href={area.href} class={`reveal reveal-delay-${i + 1} group relative rounded-2xl overflow-hidden ${i === 0 ? 'md:row-span-2' : ''}`}>
            <img
              src={area.image}
              alt={area.name}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
              <h3 class="text-white font-headline text-2xl md:text-3xl font-extrabold mb-1">{area.name}</h3>
              <p class="text-white/60 text-sm mb-4">{area.tagline}</p>
              <div class="flex gap-3">
                <span class="bg-white/10 backdrop-blur-sm text-white/80 text-xs font-semibold px-3 py-1.5 rounded-full">
                  {area.venues} Venues
                </span>
                <span class="bg-white/10 backdrop-blur-sm text-white/80 text-xs font-semibold px-3 py-1.5 rounded-full">
                  {area.hotels} Hotels
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>


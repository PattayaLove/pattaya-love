    imageAlt: 'Relaxed lifestyle and wellness in Pattaya',
    imageRight: false,
  },
];

const journalArticles = [
  {
    tag: 'Gastronomy',
    date: 'Mar 2026',
    title: 'The 5 Best Rooftop Restaurants on Pratamnak Hill',
    description: 'Elevated dining experiences that combine world-class flavors with the most iconic sunset views in Thailand.',
    href: '/guides/rooftop-dining/',
    image: '/images/trending/rooftop-dining.webp',
    aspect: 'aspect-[3/4]',
  },
  {
    tag: 'Adventure',
    date: 'Feb 2026',
    title: 'Private Charters: Beyond Koh Larn\'s Main Beaches',
    description: '',
    href: '/guides/yacht-charters/',
    image: '/images/guides/yacht-drone-own.webp',
    aspect: 'aspect-square',
  },
  {
    tag: 'Lifestyle',
    date: 'Jan 2026',
    title: 'The Ultimate Guide to Premium Living in Jomtien',
    description: 'Why Jomtien is becoming the new gold standard for discerning expatriates and international residents.',
    href: '/lifestyle/',
    image: '/images/categories/lifestyle.webp',
    aspect: 'aspect-[4/5]',
  },
  {
    tag: 'Report',
    date: 'Dec 2025',
    title: 'Skyline Transformations: The High-Rise Evolution',
    description: '',
    href: '/guides/pattaya-condos-real-estate/',

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allGuides = await getCollection('guides', ({ data }) => !data.draft);
const lifestyleGuides = allGuides
  .filter((g) => ['tips', 'general'].includes(g.data.category))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const topics = [
  { icon: 'description', title: 'Visa & Immigration', desc: 'Tourist visas, extensions, retirement visas, and Elite visa options for long-term stays.', tag: 'Coming Soon' },
  { icon: 'local_hospital', title: 'Healthcare', desc: 'International hospitals, dental clinics, health insurance, and medical tourism in Pattaya.', tag: 'Coming Soon' },
  { icon: 'gavel', title: 'Legal Advice', desc: 'Property rental disputes, legal representation, and understanding Thai law as a foreigner.', tag: 'Coming Soon' },
  { icon: 'two_wheeler', title: 'Scooter & Transport', desc: 'Renting a Honda PCX or Forza, driving licenses, insurance, and getting around safely.', tag: 'Coming Soon' },
  { icon: 'apartment', title: 'Condos & Living', desc: 'Best condos for expats, rental prices, areas to live, and long-term lease tips.', tag: 'Coming Soon' },
  { icon: 'account_balance', title: 'Banking & Finance', desc: 'Opening a Thai bank account, transferring money, and managing finances abroad.', tag: 'Coming Soon' },
];
---

<BaseLayout
  title="Expat Life in Pattaya — Visa, Legal & Lifestyle Guides"
  description="Practical guides for expats and long-term visitors in Pattaya. Visa, healthcare, legal advice, scooter rental, banking, and condo guides."
>
  <Navigation />

  <!-- Hero -->
  <header class="relative pt-32 pb-20 bg-surface">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <nav class="text-sm text-ink-muted mb-8">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-ink">Lifestyle & Expat</span>
      </nav>
      <h1 class="text-4xl md:text-6xl font-extrabold font-headline tracking-tight text-ink mb-4">
        Lifestyle & Expat
      </h1>
      <p class="text-ink-muted text-lg max-w-2xl">
        Practical guides for living in Pattaya — visa, healthcare, legal, transport, and everything you need for a smooth life in Thailand.
      </p>
      <div class="h-1 w-16 bg-primary mt-6 rounded-full"></div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Topic Grid -->
    <section class="py-20">
      <h2 class="text-3xl font-extrabold font-headline tracking-tight text-ink mb-10 reveal">Expat Essentials</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {topics.map((topic, i) => (
          <div class={`reveal reveal-delay-${(i % 4) + 1} bg-surface-card rounded-2xl p-8 border border-surface-high/30 hover:shadow-lg transition-all duration-300`}>
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center">
                <span class="material-symbols-outlined text-primary text-2xl">{topic.icon}</span>
              </div>
              <span class="text-[10px] font-bold uppercase tracking-widest text-ink-faint bg-surface-low px-3 py-1 rounded-full">{topic.tag}</span>
            </div>
            <h3 class="font-headline font-bold text-lg text-ink mb-2">{topic.title}</h3>
            <p class="text-ink-muted text-sm leading-relaxed">{topic.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Existing Guides -->
    {lifestyleGuides.length > 0 && (
      <section class="py-20 border-t border-surface-high/50">
        <div class="flex items-end justify-between mb-10 reveal">
          <div>
            <h2 class="text-3xl font-extrabold font-headline tracking-tight text-ink">Latest Guides</h2>
            <div class="h-1 w-14 bg-primary mt-3 rounded-full"></div>
          </div>
          <a href="/guides/" class="text-primary font-bold text-sm uppercase tracking-widest flex items-center gap-1 hover:gap-2 transition-all">
            All Guides <span class="material-symbols-outlined text-lg">arrow_right_alt</span>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {lifestyleGuides.slice(0, 3).map((guide, i) => (
            <a href={`/guides/${guide.data.slug}/`} class={`reveal reveal-delay-${i + 1} group bg-surface-card rounded-2xl shadow-[0_4px_20px_-4px_rgba(0,0,0,0.06)] overflow-hidden hover:shadow-lg transition-all duration-500 hover:-translate-y-1`}>
              <div class="aspect-video bg-surface-low flex items-center justify-center">
                <span class="material-symbols-outlined text-5xl text-ink-faint/30">article</span>
              </div>
              <div class="p-6">
                <h3 class="text-lg font-bold font-headline text-ink mb-2 group-hover:text-primary transition-colors line-clamp-2">{guide.data.title}</h3>
                <p class="text-ink-muted text-sm line-clamp-2">{guide.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>

  <section class="relative bg-coral py-24 overflow-hidden">
    <div class="absolute -top-20 -right-20 w-64 h-64 bg-white/5 rounded-full"></div>
    <div class="absolute -bottom-16 -left-16 w-48 h-48 bg-white/5 rounded-full"></div>
    <div class="max-w-2xl mx-auto px-6 text-center relative z-10">
      <h2 class="text-white text-3xl md:text-4xl font-extrabold font-headline tracking-tight mb-4">
        Join the Pattaya Community
      </h2>
      <p class="text-white/70 text-lg mb-10">
        Connect with travelers & expats, share experiences, and get real-time tips from people who live here.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://www.facebook.com/pattaya.xxx/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-white text-coral px-8 h-14 rounded-full font-bold text-sm uppercase tracking-widest hover:scale-105 active:scale-95 transition-transform shadow-lg whitespace-nowrap">
          <span class="material-symbols-outlined text-lg">group</span>
          Join on Facebook
        </a>
        <a href="https://www.instagram.com/pattaya.loves" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 border-2 border-white text-white px-8 h-14 rounded-full font-bold text-sm uppercase tracking-widest hover:bg-white hover:text-coral transition-all duration-300 whitespace-nowrap">
          <span class="material-symbols-outlined text-lg">photo_camera</span>
          Follow on Instagram
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

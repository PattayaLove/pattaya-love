---
interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;

const navLinks = [
  { label: 'Stay', href: '/stay/' },
  { label: 'Explore', href: '/explore/' },
  { label: 'Nightlife', href: '/nightlife/' },
  { label: 'Lifestyle', href: '/lifestyle/' },
  { label: 'Community', href: '/community/' },
];

const initialNavClass = transparent ? 'bg-transparent' : 'bg-white/85 backdrop-blur-xl shadow-sm';
const initialLogoClass = transparent ? 'text-white' : 'text-ink';
const initialLinkClass = transparent ? 'text-white/80 hover:text-white hover:bg-white/10' : 'text-ink-secondary hover:text-ink hover:bg-ink/5';
const initialBarClass = transparent ? 'bg-white' : 'bg-ink';
import Icon from './Icon.astro';
---

<nav id="main-nav" class:list={['fixed top-0 w-full z-50 transition-all duration-500', initialNavClass]} data-transparent={transparent ? 'true' : 'false'}>
  <div class="max-w-7xl mx-auto flex items-center justify-between px-6 lg:px-8 py-4">
    <!-- Logo (dark + white variants, switched on scroll) -->
    <a href="/" class="block" id="nav-logo">
      <img id="logo-dark" src="/images/brand/logo.svg" alt="pattaya.love" class:list={['h-10 w-auto transition-opacity duration-300', transparent ? 'hidden' : '']} loading="eager" />
      <img id="logo-white" src="/images/brand/logo-white.svg" alt="pattaya.love" class:list={['h-10 w-auto transition-opacity duration-300', transparent ? '' : 'hidden']} loading="eager" />
    </a>

    <!-- Desktop Nav -->
    <div class="hidden lg:flex items-center gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={['nav-link relative px-4 py-2 text-sm font-medium transition-all duration-300 rounded-lg', initialLinkClass]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- CTA + Mobile Toggle -->
    <div class="flex items-center gap-3">
      <a href="https://www.facebook.com/groups/pattaya.love" target="_blank" rel="noopener noreferrer" class="hidden sm:inline-flex cta-gradient text-white px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-widest hover:scale-105 active:scale-95 transition-transform duration-200 shadow-lg shadow-primary/20">
        Community
      </a>
      <button id="mobile-toggle" class="lg:hidden flex flex-col gap-1.5 p-2" aria-label="Menu">
        <span class:list={['block w-6 h-0.5 rounded-full transition-all duration-300', initialBarClass]} id="bar1"></span>
        <span class:list={['block w-6 h-0.5 rounded-full transition-all duration-300', initialBarClass]} id="bar2"></span>
        <span class:list={['block w-4 h-0.5 rounded-full transition-all duration-300 ml-auto', initialBarClass]} id="bar3"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden fixed inset-0 top-0 bg-navy/98 backdrop-blur-xl z-40 flex flex-col items-center justify-center gap-6 opacity-0 pointer-events-none transition-all duration-500">
    <button id="mobile-close" class="absolute top-6 right-6 text-white p-2" aria-label="Close">
      <Icon name="close" class="text-3xl" />
    </button>
    {navLinks.map((link) => (
      <a href={link.href} class="text-3xl font-headline font-bold text-white/90 hover:text-primary transition-colors">
        {link.label}
      </a>
    ))}
    <a href="https://www.facebook.com/groups/pattaya.love" target="_blank" rel="noopener noreferrer" class="mt-4 cta-gradient text-white px-8 py-3 rounded-full text-sm font-bold uppercase tracking-widest">
      Community
    </a>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav')!;
  const logoDark = document.getElementById('logo-dark')!;
  const logoWhite = document.getElementById('logo-white')!;
  const navLinks = document.querySelectorAll('.nav-link');
  const toggle = document.getElementById('mobile-toggle')!;
  const bars = [document.getElementById('bar1')!, document.getElementById('bar2')!, document.getElementById('bar3')!];
  const menu = document.getElementById('mobile-menu')!;
  const close = document.getElementById('mobile-close')!;
  const isTransparent = nav.dataset.transparent === 'true';

  let scrolled = !isTransparent;
  const applyScrolled = () => {
    nav.classList.add('bg-white/85', 'backdrop-blur-xl', 'shadow-sm');
    nav.classList.remove('bg-transparent');
    logoDark.classList.remove('hidden');
    logoWhite.classList.add('hidden');
    bars.forEach(b => { b.classList.remove('bg-white'); b.classList.add('bg-ink'); });
    navLinks.forEach(l => {
      l.classList.remove('text-white/80', 'hover:text-white', 'hover:bg-white/10');
      l.classList.add('text-ink-secondary', 'hover:text-ink', 'hover:bg-ink/5');
    });
  };
  const applyTransparent = () => {
    nav.classList.remove('bg-white/85', 'backdrop-blur-xl', 'shadow-sm');
    nav.classList.add('bg-transparent');
    logoDark.classList.add('hidden');
    logoWhite.classList.remove('hidden');
    bars.forEach(b => { b.classList.add('bg-white'); b.classList.remove('bg-ink'); });
    navLinks.forEach(l => {
      l.classList.add('text-white/80', 'hover:text-white', 'hover:bg-white/10');
      l.classList.remove('text-ink-secondary', 'hover:text-ink', 'hover:bg-ink/5');
    });
  };

  if (isTransparent) {
    const onScroll = () => {
      const shouldBeScrolled = window.scrollY > 80;
      if (shouldBeScrolled !== scrolled) {
        scrolled = shouldBeScrolled;
        scrolled ? applyScrolled() : applyTransparent();
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Mobile menu
  toggle.addEventListener('click', () => {
    menu.classList.remove('opacity-0', 'pointer-events-none');
    menu.classList.add('opacity-100', 'pointer-events-auto');
    document.body.style.overflow = 'hidden';
  });
  const closeMenu = () => {
    menu.classList.add('opacity-0', 'pointer-events-none');
    menu.classList.remove('opacity-100', 'pointer-events-auto');
    document.body.style.overflow = '';
  };
  close.addEventListener('click', closeMenu);
  menu.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));
</script>

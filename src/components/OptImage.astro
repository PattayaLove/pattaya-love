---
/**
 * OptImage — Wrapper around Astro's <Image /> with fallback.
 * Automatically converts to WebP/AVIF, resizes, and optimizes.
 * Falls back to regular <img> if the source is external or SVG.
 */
import { Image } from 'astro:assets';

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const { src, alt, width, height, class: className, loading = 'lazy', fetchpriority } = Astro.props;

// Map public paths to src/assets imports
const imageMap: Record<string, () => Promise<{ default: ImageMetadata }>> = {
  '/images/areas/walking-street.webp': () => import('../assets/images/areas/walking-street.webp'),
  '/images/areas/soi-6.webp': () => import('../assets/images/areas/soi-6.webp'),
  '/images/areas/pattaya-beach.webp': () => import('../assets/images/areas/pattaya-beach.webp'),
  '/images/areas/pattaya-panorama.webp': () => import('../assets/images/areas/pattaya-panorama.webp'),
  '/images/areas/pattaya-drone-sunset.webp': () => import('../assets/images/areas/pattaya-drone-sunset.webp'),
  '/images/areas/central-pattaya-aerial.webp': () => import('../assets/images/areas/central-pattaya-aerial.webp'),
  '/images/areas/pattaya-skyline-sunset.webp': () => import('../assets/images/areas/pattaya-skyline-sunset.webp'),
  '/images/areas/lk-metro.webp': () => import('../assets/images/areas/lk-metro.webp'),
  '/images/areas/tree-town.webp': () => import('../assets/images/areas/tree-town.webp'),
  '/images/areas/agogo-walking-street.webp': () => import('../assets/images/areas/agogo-walking-street.webp'),
  '/images/venues/iron-club.webp': () => import('../assets/images/venues/iron-club.webp'),
  '/images/venues/pin-up-agogo.webp': () => import('../assets/images/venues/pin-up-agogo.webp'),
  '/images/venues/xs-agogo.webp': () => import('../assets/images/venues/xs-agogo.webp'),
  '/images/venues/hilton-pattaya.webp': () => import('../assets/images/venues/hilton-pattaya.webp'),
  '/images/venues/melia-hotel-pattaya.webp': () => import('../assets/images/venues/melia-hotel-pattaya.webp'),
  '/images/guides/hotels-soi-6.webp': () => import('../assets/images/guides/hotels-soi-6.webp'),
  '/images/guides/bangkok-to-pattaya.webp': () => import('../assets/images/guides/bangkok-to-pattaya.webp'),
  '/images/guides/central-festival-pattaya.webp': () => import('../assets/images/guides/central-festival-pattaya.webp'),
  '/images/guides/pattaya-bus-terminal.webp': () => import('../assets/images/guides/pattaya-bus-terminal.webp'),
  '/images/guides/baht-bus.webp': () => import('../assets/images/guides/baht-bus.webp'),
  '/images/guides/hilton-rooftop-laser.webp': () => import('../assets/images/guides/hilton-rooftop-laser.webp'),
  '/images/guides/terminal-21-interior.webp': () => import('../assets/images/guides/terminal-21-interior.webp'),
  '/images/venues/hilton-drone.webp': () => import('../assets/images/venues/hilton-drone.webp'),
  '/images/venues/centric-sea-sunset.webp': () => import('../assets/images/venues/centric-sea-sunset.webp'),
  '/images/venues/the-base-pool.webp': () => import('../assets/images/venues/the-base-pool.webp'),
  '/images/venues/siam-at-siam-drone.webp': () => import('../assets/images/venues/siam-at-siam-drone.webp'),
  '/images/venues/beach-club-restaurant.webp': () => import('../assets/images/venues/beach-club-restaurant.webp'),
  '/images/venues/lay-beach-club.webp': () => import('../assets/images/venues/lay-beach-club.webp'),
  '/images/venues/byblos-beach-bar.webp': () => import('../assets/images/venues/byblos-beach-bar.webp'),
  '/images/areas/walking-street-night.webp': () => import('../assets/images/areas/walking-street-night.webp'),
  '/images/areas/soi-6-sign.webp': () => import('../assets/images/areas/soi-6-sign.webp'),
  '/images/areas/sunset-pattaya-beach.webp': () => import('../assets/images/areas/sunset-pattaya-beach.webp'),
  '/images/areas/pratumnak-viewpoint.webp': () => import('../assets/images/areas/pratumnak-viewpoint.webp'),
  '/images/areas/sanctuary-of-truth.webp': () => import('../assets/images/areas/sanctuary-of-truth.webp'),
  '/images/areas/bali-hai-sunset.webp': () => import('../assets/images/areas/bali-hai-sunset.webp'),
  '/images/brand/heart-sunset.webp': () => import('../assets/images/brand/heart-sunset.webp'),
  '/images/brand/logo.webp': () => import('../assets/images/brand/logo.webp'),
  '/images/areas/lk-metro-night.webp': () => import('../assets/images/areas/lk-metro-night.webp'),
  '/images/venues/siam-siam-rooftop-sunset.webp': () => import('../assets/images/venues/siam-siam-rooftop-sunset.webp'),
  '/images/guides/siam-siam-sunset-view.webp': () => import('../assets/images/guides/siam-siam-sunset-view.webp'),
  '/images/venues/the-base-building.webp': () => import('../assets/images/venues/the-base-building.webp'),
  '/images/areas/pattaya-city-sign.webp': () => import('../assets/images/areas/pattaya-city-sign.webp'),
  '/images/guides/pattaya-night-bazaar.webp': () => import('../assets/images/guides/pattaya-night-bazaar.webp'),
};

const loader = imageMap[src];
let resolvedImage: ImageMetadata | null = null;

if (loader) {
  try {
    const mod = await loader();
    resolvedImage = mod.default;
  } catch {
    resolvedImage = null;
  }
}
---

{resolvedImage ? (
  <Image
    src={resolvedImage}
    alt={alt}
    width={width || resolvedImage.width}
    height={height || resolvedImage.height}
    format="webp"
    quality={80}
    class={className}
    loading={loading}
    decoding="async"
  />
) : (
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    class={className}
    loading={loading}
    decoding="async"
  />
)}
